# Server-only credentials (tidak dikirim ke client)
TURSO_DATABASE_URL=your_turso_url
TURSO_AUTH_TOKEN=your_turso_token
TMDB_API_KEY=your_tmdb_api_key
TMDB_READ_ACCESS_TOKEN=your_tmdb_token
RAPIDAPI_KEY=your_rapidapi_key

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Client-only config (aman untuk public)
VITE_APP_NAME=Cinevora
# VITE_API_BASE_URL — jangan diset di production! Biarkan kosong agar pakai '/api' (Cloudflare Functions)
# VITE_API_BASE_URL=http://localhost:3001/api